  {
    "id": "find_large_files_windows_powershell",
    "task": "find_large_files",
    "platform": "windows",
    "shell": "powershell",
    "warning": "safe",
    "command": "Get-ChildItem -Path . -File -Recurse | Where-Object { $_.Length -gt 100MB }",
    "example": "Get-ChildItem -Path C:\\logs -File -Recurse | Where-Object { $_.Length -gt 500MB }",
    "description": {
      "de": "Findet Dateien groesser als 100 MB rekursiv.",
      "en": "Finds files larger than 100 MB recursively."
    },
    "keywords": {
      "de": ["grosse dateien", "dateien finden", "dateigroesse", "rekursiv"],
      "en": ["find large files", "file size", "big files", "recursive"]
    }
  },
  {
    "id": "find_large_files_linux_bash",
    "task": "find_large_files",
