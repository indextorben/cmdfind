{
  "name": "cmdfind",
  "version": "0.1.0",
  "description": "Find terminal commands from natural language (DE/EN) for Windows, Linux and macOS",
  "author": {
    "name": "indextorben",
    "email": "indextorben@users.noreply.github.com"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cmdfind": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "desktop": "npm run build && npx electron-rebuild -f -w node-pty && node -e \"const { spawn } = require('child_process'); const electron = require('electron'); const env = { ...process.env }; delete env.ELECTRON_RUN_AS_NODE; const child = spawn(electron, ['dist/desktop/main.js'], { stdio: 'inherit', env }); child.on('exit', (code) => process.exit(code ?? 0));\"",
    "desktop:package": "npm run build && npx electron-rebuild -f -w node-pty && electron-builder --publish never",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "electron": "^35.3.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.indextorben.cmdfind",
    "productName": "cmdfind",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/desktop/main.js"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Development",
      "maintainer": "indextorben <indextorben@users.noreply.github.com>"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "indextorben",
        "repo": "cmdfind",
        "releaseType": "prerelease"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "node-pty": "^1.1.0"
  }
}
