{
  "name": "cmdfind",
  "version": "0.1.0",
  "description": "Find terminal commands from natural language (DE/EN) for Windows, Linux and macOS",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cmdfind": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/data dist/desktop && cp src/data/commands.json dist/data/commands.json && cp src/data/it-commands.json dist/data/it-commands.json && cp src/desktop/index.html dist/desktop/index.html",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "desktop": "npm run build && electron dist/desktop/main.js",
    "desktop:package": "npm run build && electron-builder --publish never",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "electron": "^35.3.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.indextorben.cmdfind",
    "productName": "cmdfind",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/desktop/main.js"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Development"
    }
  }
}
